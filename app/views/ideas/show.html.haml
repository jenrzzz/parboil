%nav.crumb= link_to "← all ideas", root_path

%header.idea-header
  %h1= @idea.display_title
  - if @idea.audience.present?
    %p.audience for: #{@idea.audience}
  %blockquote.seed= @idea.seed

- if @idea.head_hash.present?
  %section.ripeness{ class: (@idea.ripe? ? "is-ripe" : nil) }
    - if @idea.ripe?
      %p.ripe-banner
        Ready to draft — the checklist is met. Pull the outline and go write.
        Keep interviewing if it's still simmering.
    %ul.checklist
      - @ripeness.checks.each do |check|
        %li{ class: (check.met ? "met" : "unmet") }
          %span.tick= check.met ? "✓" : "○"
          %span.label= check.label
          - if check.detail
            %span.detail= check.detail

-# The re-entry ritual: recap first, then exactly ONE next question.
- if @nodes_by_type.any?
  %section.recap
    %h2 The graph so far
    = render "graph", graph: @graph
    %details.as-list
      %summary as a list
      - IdeaNode.node_types.each_key do |type|
        - nodes = @nodes_by_type[type]
        - next if nodes.blank?
        .node-group{ class: type }
          %h3= type.pluralize(nodes.size)
          %ul
            - nodes.each do |node|
              %li{ class: (node.open? ? "open" : nil) }
                - if node.thesis?
                  %strong thesis:
                = node.body

%section.scraps
  %h2 raw material
  - if @idea.scraps.any?
    %ul.scrap-list
      - @idea.scraps.ordered.each do |scrap|
        %li
          - if scrap.link?
            = link_to scrap.display_title, scrap.url, target: "_blank", rel: "noopener"
            %span.host= scrap.host
            - if scrap.unfetched?
              %span.unfetched link only
          - else
            %details
              %summary= scrap.display_title
              %p.scrap-body= scrap.body
          = button_to "remove", scrap_path(scrap), method: :delete, class: "quiet", form_class: "inline"
  %details.drop-in
    %summary Drop something in — a link or pasted text the interview should know about
    = form_with url: idea_scraps_path(@idea), scope: :scrap do |f|
      = f.url_field :url, placeholder: "https:// — an article, a thread, prior art"
      = f.text_area :body, rows: 4, placeholder: "…or paste text: a quote, your old notes, someone's take"
      = f.submit "Add to the pot"

%section.turn
  - if @idea.head_hash.blank?
    %p.coax The interview hasn't started. One question at a time; answering one is a whole session.
    = button_to "Start the interview", next_question_idea_path(@idea), class: "primary"
  - elsif @conductor.awaiting_question?
    %p.coax Your answer is saved — the next question never arrived.
    = button_to "Ask me the next question", next_question_idea_path(@idea), class: "primary"
  - elsif (question = @conductor.pending_question)
    .question
      %p= question.content
    = form_with url: answer_idea_path(@idea) do |f|
      = f.text_area :answer, rows: 5, placeholder: "Answer in your own words — the graph grows from what you say.", required: true, autofocus: true
      = f.submit "Answer"

- if @transcript.present?
  %details.transcript
    %summary Full interview (#{@transcript.size} turns)
    - @transcript.each do |node|
      .turn-row{ class: node.role }
        %span.speaker= node.interviewer? ? "interviewer" : "you"
        %p= node.content

- if @idea.idea_nodes.any?
  %footer.handoff
    = link_to "View outline (markdown)", outline_idea_path(@idea, format: :md)
    %code.curl curl #{outline_idea_url(@idea)}
